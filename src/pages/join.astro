---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import qrCodeImg from "../constants/images/card.jpg";

const title = "加入我们 | 建立连接";
const description =
  "一个人可以走得很快，但一群人可以走得很远。期待与你交流学习、资源互通、岗位互推。";
---

<MainGridLayout title={title} description={description}>
  <script
    src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"
    is:inline></script>

  <div class="w-full flex flex-col gap-6 relative z-10">
    
    {/* ✨ 模块一：头部宣言区 */}
    <div class="bg-[var(--card-bg)] rounded-[2rem] p-8 md:p-10 border border-[var(--line-divider)] shadow-sm relative overflow-hidden flex flex-col-reverse md:flex-row items-center gap-8 justify-between">
      <div class="absolute -top-20 -right-20 w-72 h-72 bg-blue-500/10 dark:bg-blue-400/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="flex-1 relative z-10 text-center md:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800/50 mb-5 shadow-sm">
          <Icon name="fa6-solid:handshake" class="text-sm animate-pulse" />
          <span class="text-xs font-bold tracking-wider">CONNECT WITH ME</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-black mb-4 text-transparent bg-clip-text bg-gradient-to-br from-blue-600 to-indigo-500 dark:from-blue-400 dark:to-indigo-300 drop-shadow-sm tracking-tight">
          让链接产生价值
        </h1>
        <p class="text-[var(--content)] opacity-85 text-sm md:text-base leading-relaxed text-balance font-medium">
          无论你是前端大佬、后端极客、产品大牛，还是正在迷茫的行业新人。在这里，我们不谈职场 PUA，只做纯粹的技术交流与搞钱搭子。
        </p>
      </div>

      <div class="w-48 h-48 md:w-56 md:h-56 shrink-0 relative z-10 drop-shadow-xl hover:scale-105 transition-transform duration-500">
        <lottie-player src="https://lottie.host/04634570-6436-49a5-9f3a-7d84edc23ebc/oYgzPCZWJb.json" background="transparent" speed="1" style="width: 100%; height: 100%;" loop autoplay></lottie-player>
      </div>
    </div>

    {/* ✨ 模块二：价值主张 */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {/* 交流学习 */}
      <div class="bg-[var(--card-bg)] p-6 rounded-[2rem] border border-[var(--line-divider)] shadow-sm hover:-translate-y-1 hover:shadow-md transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 shrink-0 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400 group-hover:scale-110 group-hover:rotate-3 transition-transform">
            <Icon name="fa6-solid:lightbulb" class="text-xl" />
          </div>
          <h3 class="text-lg font-bold text-[var(--content)] m-0">交流学习</h3>
        </div>
        <p class="text-sm text-[var(--content)] opacity-70 leading-relaxed">全栈开发、PMP项目管理、AI应用落地，随时探讨，拒绝闭门造车。</p>
      </div>
      
      {/* 资源互通 */}
      <div class="bg-[var(--card-bg)] p-6 rounded-[2rem] border border-[var(--line-divider)] shadow-sm hover:-translate-y-1 hover:shadow-md transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 shrink-0 rounded-xl bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-600 dark:text-purple-400 group-hover:scale-110 group-hover:-rotate-3 transition-transform">
            <Icon name="fa6-solid:link" class="text-xl" />
          </div>
          <h3 class="text-lg font-bold text-[var(--content)] m-0">资源互通</h3>
        </div>
        <p class="text-sm text-[var(--content)] opacity-70 leading-relaxed">工具分享、开源项目共建、副业搞钱思路碰撞。闲置资源变现刚需。</p>
      </div>

      {/* 岗位互推 */}
      <div class="bg-[var(--card-bg)] p-6 rounded-[2rem] border border-[var(--line-divider)] shadow-sm hover:-translate-y-1 hover:shadow-md transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 shrink-0 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400 group-hover:scale-110 group-hover:rotate-3 transition-transform">
            <Icon name="fa6-solid:briefcase" class="text-xl" />
          </div>
          <h3 class="text-lg font-bold text-[var(--content)] m-0">岗位互推</h3>
        </div>
        <p class="text-sm text-[var(--content)] opacity-70 leading-relaxed">打破信息差！优质简历直达内推人，靠谱坑位优先内部分享。</p>
      </div>

      {/* 专属树洞 */}
      <div class="bg-[var(--card-bg)] p-6 rounded-[2rem] border border-[var(--line-divider)] shadow-sm hover:-translate-y-1 hover:shadow-md transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 shrink-0 rounded-xl bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-rose-600 dark:text-rose-400 group-hover:scale-110 group-hover:-rotate-3 transition-transform">
            <Icon name="fa6-solid:mug-hot" class="text-xl" />
          </div>
          <h3 class="text-lg font-bold text-[var(--content)] m-0">专属树洞</h3>
        </div>
        <p class="text-sm text-[var(--content)] opacity-70 leading-relaxed">有些话朋友圈发不了。这里是你卸下防备的倾诉角落。</p>
      </div>
    </div>

{/* ✨ 模块三：三大核心连接入口 (三栏对称网格) */}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
      
  {/* 1. 微信生态卡片 */}
  <div class="bg-[var(--card-bg)] rounded-[2rem] p-6 lg:p-8 border border-[var(--line-divider)] shadow-sm flex flex-col items-center justify-between relative overflow-hidden bg-gradient-to-b from-transparent to-emerald-50/30 dark:to-emerald-900/5 group">
    <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-emerald-500/10 dark:bg-emerald-400/5 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="w-full flex flex-col items-center">
      <div class="text-center mb-6 relative z-10">
        <span class="inline-block px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 text-[10px] md:text-xs font-bold tracking-widest mb-3 border border-emerald-200 dark:border-emerald-800/50">
          WECHAT COMMUNITY
        </span>
        <h2 class="text-lg md:text-xl font-bold text-[var(--content)] flex items-center justify-center gap-2">
          <Icon name="fa6-brands:weixin" class="text-[#07C160] text-2xl" /> 微信圈子
        </h2>
      </div>

      {/* 二维码区域 */}
      <div class="relative group/qr mb-6 z-10">
        <div class="absolute -inset-1 bg-gradient-to-r from-emerald-400 to-teal-500 rounded-2xl blur opacity-25 group-hover/qr:opacity-50 transition duration-500"></div>
        <img src={qrCodeImg.src} alt="西瓜的微信二维码" class="relative w-36 h-36 lg:w-44 lg:h-44 object-contain rounded-2xl shadow-lg border-2 border-white dark:border-zinc-700 bg-white p-2 transition-transform duration-500 group-hover/qr:scale-105" />
        
        <button 
          onclick="openQrModal()" 
          class="absolute -bottom-3 -right-3 bg-white dark:bg-zinc-800 rounded-full p-2.5 shadow-xl border border-gray-100 dark:border-zinc-700 z-10 hover:scale-110 hover:text-emerald-600 transition-all cursor-pointer group/btn flex items-center justify-center"
          title="点击放大查看"
        >
          <Icon name="fa6-solid:qrcode" class="text-xl text-emerald-500 transition-transform group-hover/btn:scale-110" />
        </button>
      </div>

      <div class="flex flex-col items-center w-full max-w-[240px] z-10 mb-4">
        <button id="copy-btn" class="group/copy relative flex items-center gap-3 px-4 py-2.5 bg-white dark:bg-zinc-900 border border-gray-200 dark:border-zinc-700 rounded-xl hover:border-emerald-500 transition-all shadow-sm w-full justify-between overflow-hidden" onclick="copyWechatId()">
          <span class="font-mono font-bold text-sm lg:text-base text-[var(--content)] group-hover/copy:text-emerald-600 transition-colors">shenwan96</span>
          <Icon name="fa6-solid:copy" class="text-gray-400 group-hover/copy:text-emerald-500 transition-colors" />
          <div id="copy-success" class="absolute inset-0 bg-emerald-500 flex items-center justify-center text-white font-bold text-sm translate-y-full transition-transform duration-300">已复制 🎉</div>
        </button>
      </div>
    </div>

    <p class="text-[11px] text-emerald-600/80 dark:text-emerald-400/80 font-medium bg-emerald-50 dark:bg-emerald-900/20 px-3 py-1.5 rounded-lg border border-emerald-100 dark:border-emerald-800/30 z-10 w-full text-center mt-auto">
      <Icon name="fa6-solid:pen" class="inline text-[9px] mr-1" /> 添加时备注"博客粉丝"哦
    </p>
  </div>

  {/* 2. Discord 频道卡片 */}
  <div class="bg-[var(--card-bg)] rounded-[2rem] p-6 lg:p-8 border border-[var(--line-divider)] shadow-sm flex flex-col items-center justify-between relative overflow-hidden bg-gradient-to-b from-transparent to-[#5865F2]/5 dark:to-[#5865F2]/10 group">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-[#5865F2]/10 dark:bg-[#5865F2]/20 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="w-full flex flex-col items-center">
      <div class="text-center mb-6 relative z-10">
        <span class="inline-block px-3 py-1 rounded-full bg-[#5865F2]/10 text-[#5865F2] dark:text-[#5865F2] text-[10px] md:text-xs font-bold tracking-widest mb-3 border border-[#5865F2]/20">
          INTERNATIONAL
        </span>
        <h2 class="text-lg md:text-xl font-bold text-[var(--content)] flex items-center justify-center gap-2">
          <Icon name="fa6-brands:discord" class="text-[#5865F2] text-2xl" /> Discord
        </h2>
      </div>

      <div class="relative group/logo mb-8 mt-2 z-10">
        <div class="absolute -inset-4 bg-gradient-to-r from-[#5865F2] to-indigo-400 rounded-full blur-xl opacity-40 group-hover/logo:opacity-70 transition duration-500 animate-pulse"></div>
        <div class="relative w-28 h-28 lg:w-32 lg:h-32 bg-[#5865F2] rounded-3xl flex items-center justify-center shadow-[0_8px_30px_rgb(88,101,242,0.4)] group-hover/logo:scale-110 group-hover/logo:-rotate-3 transition-transform duration-500">
          <Icon name="fa6-brands:discord" class="text-white text-6xl lg:text-7xl" />
          <div class="absolute bottom-1.5 right-1.5 w-5 h-5 lg:w-6 lg:h-6 bg-green-500 border-4 border-[#5865F2] rounded-full"></div>
        </div>
      </div>

      <p class="text-[13px] text-[var(--content)] opacity-75 text-center leading-relaxed mb-6 max-w-[240px] z-10">
        代码高亮分享、多端语音闲聊、机器人自动化通知。纯粹的极客交流基地。
      </p>
    </div>

    <a href="https://discord.gg/gqxeFx5H" target="_blank" class="relative z-10 w-full max-w-[240px] flex items-center justify-center gap-2 px-6 py-3 bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold rounded-xl transition-all shadow-[0_4px_14px_0_rgba(88,101,242,0.39)] hover:-translate-y-0.5 active:scale-95 mt-auto">
      <Icon name="fa6-solid:paper-plane" class="text-base" />
      <span class="text-sm">加入频道</span>
    </a>
  </div>

  {/* 3. GitHub 开源共建卡片 */}
  <div class="bg-[var(--card-bg)] rounded-[2rem] p-6 lg:p-8 border border-[var(--line-divider)] shadow-sm flex flex-col items-center justify-between relative overflow-hidden bg-gradient-to-b from-transparent to-gray-100 dark:to-zinc-800/30 group">
    <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-gray-500/10 dark:bg-gray-400/5 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="w-full flex flex-col items-center">
      <div class="text-center mb-6 relative z-10">
        <span class="inline-block px-3 py-1 rounded-full bg-gray-100 dark:bg-zinc-800 text-gray-600 dark:text-gray-300 text-[10px] md:text-xs font-bold tracking-widest mb-3 border border-gray-200 dark:border-zinc-700">
          OPEN SOURCE
        </span>
        <h2 class="text-lg md:text-xl font-bold text-[var(--content)] flex items-center justify-center gap-2">
          <Icon name="fa6-brands:github" class="text-[var(--content)] text-2xl" /> 获取源码
        </h2>
      </div>

      <div class="relative group/logo mb-8 mt-2 z-10">
        <div class="absolute -inset-4 bg-gradient-to-r from-gray-300 to-gray-400 dark:from-zinc-700 dark:to-zinc-600 rounded-full blur-xl opacity-30 group-hover/logo:opacity-60 transition duration-500"></div>
        <div class="relative w-28 h-28 lg:w-32 lg:h-32 bg-white dark:bg-zinc-800 rounded-3xl flex items-center justify-center shadow-lg border border-gray-100 dark:border-zinc-700 group-hover/logo:scale-110 group-hover/logo:rotate-3 transition-transform duration-500">
          <Icon name="fa6-brands:github" class="text-[var(--content)] text-6xl lg:text-7xl" />
        </div>
      </div>

      <p class="text-[13px] text-[var(--content)] opacity-75 text-center leading-relaxed mb-6 max-w-[240px] z-10">
        喜欢本站点的设计？源码已完全开源。欢迎提交 PR 共同维护，或赏个 Star ⭐️。
      </p>
    </div>

    <a href="https://github.com/ShenWan0906/shenwan-blog" target="_blank" class="relative z-10 w-full max-w-[240px] flex items-center justify-center gap-2 px-6 py-3 bg-zinc-900 dark:bg-gray-100 hover:bg-zinc-800 dark:hover:bg-white text-white dark:text-zinc-900 font-bold rounded-xl transition-all shadow-md hover:-translate-y-0.5 active:scale-95 mt-auto">
      <Icon name="fa6-brands:github" class="text-base" />
      <span class="text-sm">获取源码 & Star</span>
    </a>
  </div>

</div>
</div>

{/* 🔍 二维码放大弹窗 (保持不变) */}
  <div id="qr-modal" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[100] hidden flex items-center justify-center p-4 transition-opacity opacity-0" onclick="closeQrModal()">
    <div id="qr-modal-content" class="relative bg-white dark:bg-zinc-800 p-6 rounded-3xl shadow-2xl scale-95 transition-transform duration-300" onclick="event.stopPropagation()">
      <button class="absolute -top-4 -right-4 w-10 h-10 bg-white dark:bg-zinc-800 rounded-full shadow-lg flex items-center justify-center text-gray-500 hover:text-red-500 transition-colors z-10 border border-gray-100 dark:border-zinc-700" onclick="closeQrModal()">
        <Icon name="fa6-solid:xmark" class="text-xl" />
      </button>
      <img src={qrCodeImg.src} alt="微信二维码放大版" class="w-72 h-72 md:w-96 md:h-96 object-contain rounded-2xl bg-white" />
      <p class="text-center mt-6 text-sm md:text-base font-bold text-gray-700 dark:text-gray-300 flex items-center justify-center gap-2">
        <Icon name="fa6-brands:weixin" class="text-[#07C160] text-xl" /> 扫码加入微信圈子
      </p>
    </div>
  </div>

  {/* 脚本逻辑区域 */}
  <script is:inline>
    // 微信 ID 复制逻辑
    window.copyWechatId = function() {
      const wechatId = "shenwan96";
      navigator.clipboard
        .writeText(wechatId)
        .then(() => {
          const successMsg = document.getElementById("copy-success");
          successMsg.classList.remove("translate-y-full");
          setTimeout(() => {
            successMsg.classList.add("translate-y-full");
          }, 2000);
        })
        .catch((err) => {
          console.error("复制失败:", err);
          alert("复制失败，请手动复制微信号：shenwan96");
        });
    }

    // 打开二维码弹窗逻辑
    window.openQrModal = function() {
      const modal = document.getElementById("qr-modal");
      const content = document.getElementById("qr-modal-content");
      
      modal.classList.remove("hidden");
      void modal.offsetWidth; 
      
      modal.classList.remove("opacity-0");
      content.classList.remove("scale-95");
      content.classList.add("scale-100");
    }

    // 关闭二维码弹窗逻辑
    window.closeQrModal = function() {
      const modal = document.getElementById("qr-modal");
      const content = document.getElementById("qr-modal-content");
      
      modal.classList.add("opacity-0");
      content.classList.remove("scale-100");
      content.classList.add("scale-95");
      
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
    }
  </script>
</MainGridLayout>