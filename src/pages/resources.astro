---
// src/pages/resources.astro
import { resourceData } from "../constants/resources";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>资源工坊 | ShenWan Studio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* --- 1. 弹窗动画 --- */
      .modal-enter {
        opacity: 0;
        transform: scale(0.95) translateY(10px);
      }
      .modal-enter-active {
        opacity: 1;
        transform: scale(1) translateY(0);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* --- 2. 卡片瀑布流入场动画 --- */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fade-in-up {
        opacity: 0; /* 初始隐藏 */
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      /* --- 3. 标题文字流光动画 --- */
      @keyframes gradient-x {
        0%,
        100% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
      }
      .animate-gradient-x {
        background-size: 200% 200%;
        animation: gradient-x 4s ease infinite;
      }

      /* 定制滚动条 */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
      }
    </style>
  </head>
  <body
    class="bg-slate-50 text-slate-800 font-sans min-h-screen p-8 lg:p-16 relative"
    style="background-image: radial-gradient(#e2e8f0 1px, transparent 1px); background-size: 32px 32px;"
  >
    <a
      href="/"
      class="absolute top-6 left-6 lg:top-10 lg:left-12 flex items-center gap-2 px-5 py-2.5 bg-white/70 backdrop-blur-md border border-slate-200 text-slate-600 hover:text-blue-600 hover:bg-white rounded-full shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 z-40 group animate-fade-in-up"
      style="animation-delay: 0ms;"
    >
      <svg
        class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      <span class="text-sm font-bold tracking-wide">返回主站</span>
    </a>
    <div class="max-w-6xl mx-auto mt-4 md:mt-0">
      <header
        class="mb-16 text-center animate-fade-in-up"
        style="animation-delay: 100ms;"
      >
        <div
          class="inline-flex items-center justify-center px-4 py-1.5 mb-6 rounded-full bg-white border border-slate-200 shadow-sm"
        >
          <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse mr-2"
          ></span>
          <span class="text-sm font-medium text-slate-600 tracking-wide"
            >ShenWan Studio 出品</span
          >
        </div>
        <h1
          class="text-5xl font-extrabold mb-6 tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-indigo-500 to-emerald-500 animate-gradient-x"
        >
          资源工坊 Resource Workshop
        </h1>
        <p class="text-slate-500 text-lg max-w-2xl mx-auto leading-relaxed">
          精心打磨的项目管理模板、效率提升工具与核心备考资料。
          <br class="hidden sm:block" />消除重复造轮子，专注于高价值交付。
        </p>
      </header>

      {
        resourceData.map((section, secIndex) => (
          <div class="mb-16">
            <h2
              class="text-2xl font-bold text-slate-800 mb-8 flex items-center animate-fade-in-up"
              style={`animation-delay: ${secIndex * 150 + 100}ms;`}
            >
              <span class="w-8 h-1 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full mr-4" />
              {section.category}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {section.items.map((item, itemIndex) => (
                <div
                  class="bg-white/80 backdrop-blur-sm rounded-3xl p-7 border border-slate-100 flex flex-col h-full transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:bg-white animate-fade-in-up group"
                  style={`animation-delay: ${(secIndex * 3 + itemIndex) * 100 + 300}ms;`}
                >
                  <div class="flex items-center gap-4 mb-5">
                    {item.type === "public" ? (
                      <div class="shrink-0 w-12 h-12 bg-blue-50/50 rounded-2xl flex items-center justify-center text-blue-500 group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300">
                        <svg
                          class="w-6 h-6"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                          />
                        </svg>
                      </div>
                    ) : (
                      <div class="shrink-0 w-12 h-12 bg-emerald-50/50 rounded-2xl flex items-center justify-center text-emerald-500 group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-300">
                        <svg
                          class="w-6 h-6"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H7a2 2 0 01-2-2v-8z"
                          />
                        </svg>
                      </div>
                    )}
                    <h3 class="text-xl font-bold text-slate-800 leading-tight group-hover:text-blue-600 transition-colors">
                      {item.title}
                    </h3>
                  </div>

                  <p class="text-sm text-slate-500 line-clamp-3 mb-6 flex-grow leading-relaxed">
                    {item.desc}
                  </p>

                  <div class="flex flex-wrap gap-2 mb-8">
                    {item.tags.map((tag) => (
                      <span class="bg-slate-100 text-slate-600 border border-slate-200 text-xs px-3 py-1.5 rounded-lg font-medium tracking-wide">
                        {tag}
                      </span>
                    ))}
                  </div>

                  {item.type === "public" ? (
                    <div class="bg-slate-50/80 rounded-2xl p-5 border border-slate-100 mt-auto group-hover:border-blue-100 transition-colors">
                      <div class="flex justify-between items-center mb-3">
                        <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">
                          Link
                        </span>
                        <a
                          href={item.link}
                          target="_blank"
                          class="text-xs text-blue-500 hover:text-blue-600 hover:underline truncate max-w-[200px]"
                        >
                          {item.link}
                        </a>
                      </div>
                      <div class="flex justify-between items-center mb-5">
                        <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">
                          Code
                        </span>
                        <code class="bg-white border border-slate-200 text-slate-700 px-2.5 py-1 rounded-md font-mono text-sm font-bold shadow-sm">
                          {item.code}
                        </code>
                      </div>

                      <button
                        class="copy-btn w-full bg-slate-800 hover:bg-blue-600 text-white text-sm font-semibold py-3 rounded-xl transition-all duration-300 flex justify-center items-center gap-2 hover:shadow-lg hover:shadow-blue-500/25 active:scale-95"
                        data-link={item.link}
                        data-code={item.code}
                      >
                        <svg
                          class="w-4 h-4 icon-svg"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                          />
                        </svg>
                        <span class="btn-text">复制链接与密码</span>
                      </button>
                    </div>
                  ) : (
                    <div class="mt-auto">
                      <button
                        class="wechat-btn w-full bg-[#07c160] hover:bg-[#06ad56] text-white text-sm font-semibold py-4 rounded-2xl transition-all duration-300 flex justify-center items-center gap-2 shadow-[0_4px_14px_0_rgba(7,193,96,0.39)] hover:shadow-[0_6px_20px_rgba(7,193,96,0.23)] hover:-translate-y-0.5 active:scale-95"
                        data-keyword={item.keyword}
                      >
                        <svg
                          class="w-5 h-5 shrink-0"
                          viewBox="0 0 1024 1024"
                          fill="currentColor"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path d="M682.667 426.667c29.866 0 55.466 2.133 81.066 8.533C718.933 300.8 554.667 192 362.667 192 162.133 192 0 326.4 0 490.667c0 93.867 51.2 177.067 132.267 236.8l-34.134 102.4 119.467-59.733c44.8 12.8 91.733 19.2 142.933 19.2 12.8 0 27.733 0 40.534-2.133-12.8-29.867-21.334-61.867-21.334-93.867 0-147.2 134.4-266.667 302.934-266.667zM256 362.667c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm213.333 0c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm554.667 277.333c0-115.2-115.2-209.067-256-209.067s-256 93.867-256 209.067 115.2 209.067 256 209.067c38.4 0 74.667-8.533 108.8-21.333l89.6 44.8-25.6-76.8c53.333-42.667 83.2-96 83.2-155.734zm-341.333-32c-17.067 0-32-14.934-32-32s14.933-32 32-32 32 14.934 32 32-14.933 32-32 32zm170.666 0c-17.066 0-32-14.934-32-32s14.934-32 32-32 32 14.934 32 32-14.934 32-32 32z" />
                        </svg>
                        解锁专属资源
                      </button>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div
      id="wechat-modal"
      class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-50 hidden flex items-center justify-center p-4"
    >
      <div
        id="wechat-modal-content"
        class="bg-white rounded-[2rem] p-10 max-w-sm w-full shadow-2xl modal-enter text-center relative border border-slate-100"
      >
        <button
          id="close-wechat-modal"
          class="absolute top-5 right-5 w-8 h-8 flex items-center justify-center bg-slate-50 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-full transition-colors"
          >&times;</button
        >

        <div class="relative w-20 h-20 mx-auto mb-6">
          <div
            class="absolute inset-0 bg-emerald-400 blur-xl opacity-30 rounded-full animate-pulse"
          >
          </div>
          <div
            class="relative w-full h-full bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-center text-[#07c160] rotate-3 hover:rotate-0 transition-transform"
          >
            <svg class="w-10 h-10" viewBox="0 0 1024 1024" fill="currentColor"
              ><path
                d="M682.667 426.667c29.866 0 55.466 2.133 81.066 8.533C718.933 300.8 554.667 192 362.667 192 162.133 192 0 326.4 0 490.667c0 93.867 51.2 177.067 132.267 236.8l-34.134 102.4 119.467-59.733c44.8 12.8 91.733 19.2 142.933 19.2 12.8 0 27.733 0 40.534-2.133-12.8-29.867-21.334-61.867-21.334-93.867 0-147.2 134.4-266.667 302.934-266.667zM256 362.667c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm213.333 0c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm554.667 277.333c0-115.2-115.2-209.067-256-209.067s-256 93.867-256 209.067 115.2 209.067 256 209.067c38.4 0 74.667-8.533 108.8-21.333l89.6 44.8-25.6-76.8c53.333-42.667 83.2-96 83.2-155.734zm-341.333-32c-17.067 0-32-14.934-32-32s14.933-32 32-32 32 14.934 32 32-14.933 32-32 32zm170.666 0c-17.066 0-32-14.934-32-32s14.934-32 32-32 32 14.934 32 32-14.934 32-32 32z"
              ></path></svg
            >
          </div>
        </div>

        <h3 class="text-2xl font-bold text-slate-800 mb-3 tracking-tight">
          扫码获取资源
        </h3>
        <p class="text-slate-500 mb-6 font-medium">
          关注公众号，发送下方暗号即可解锁
        </p>

        <div class="p-2 bg-slate-50 rounded-2xl border border-slate-100 mb-6">
          <img
            src="/images/mp_qr.jpg"
            alt="公众号二维码"
            class="w-full h-auto rounded-xl"
          />
        </div>

        <div
          class="bg-emerald-50/50 rounded-xl py-4 px-6 inline-flex flex-col border border-emerald-100"
        >
          <span
            class="text-emerald-600/60 text-xs font-bold uppercase tracking-widest mb-1"
            >专属暗号</span
          >
          <span
            id="modal-keyword-display"
            class="font-black text-[#07c160] text-xl tracking-widest"></span>
        </div>
      </div>
    </div>

    <script is:inline>
      /* 复制逻辑 */
      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const link = this.getAttribute("data-link");
          const code = this.getAttribute("data-code");
          const textSpan = this.querySelector(".btn-text");
          const originalText = textSpan.innerText;

          try {
            await navigator.clipboard.writeText(
              `链接：${link}\n提取码：${code}`,
            );
            this.classList.replace("bg-slate-800", "bg-emerald-500");
            this.classList.replace("hover:bg-blue-600", "hover:bg-emerald-600");
            this.classList.replace(
              "hover:shadow-blue-500/25",
              "hover:shadow-emerald-500/25",
            );
            textSpan.innerText = "成功存入剪贴板";

            setTimeout(() => {
              this.classList.replace("bg-emerald-500", "bg-slate-800");
              this.classList.replace(
                "hover:bg-emerald-600",
                "hover:bg-blue-600",
              );
              this.classList.replace(
                "hover:shadow-emerald-500/25",
                "hover:shadow-blue-500/25",
              );
              textSpan.innerText = originalText;
            }, 2500);
          } catch (err) {
            alert("复制失败");
          }
        });
      });

      /* 弹窗逻辑 */
      const wechatModal = document.getElementById("wechat-modal");
      const wechatModalContent = document.getElementById(
        "wechat-modal-content",
      );
      const closeWechatBtn = document.getElementById("close-wechat-modal");
      const keywordDisplay = document.getElementById("modal-keyword-display");

      document.querySelectorAll(".wechat-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
          keywordDisplay.innerText = this.getAttribute("data-keyword");
          wechatModal.classList.remove("hidden");
          requestAnimationFrame(() =>
            wechatModalContent.classList.add("modal-enter-active"),
          );
        });
      });

      const closeWechatModal = () => {
        wechatModalContent.classList.remove("modal-enter-active");
        setTimeout(() => wechatModal.classList.add("hidden"), 300);
      };

      closeWechatBtn.addEventListener("click", closeWechatModal);
      wechatModal.addEventListener("click", (e) => {
        if (e.target === wechatModal) closeWechatModal();
      });
    </script>
  </body>
</html>
