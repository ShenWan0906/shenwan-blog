---
// src/pages/resources.astro
import { resourceData } from "../constants/resources";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>组织过程资产 | ShenWan Studio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .modal-enter {
        opacity: 0;
        transform: scale(0.95) translateY(10px);
      }
      .modal-enter-active {
        opacity: 1;
        transform: scale(1) translateY(0);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }
    </style>
  </head>
  <body class="bg-gray-50 text-gray-800 font-sans min-h-screen p-8 lg:p-16 relative">
    <div class="max-w-5xl mx-auto">
      <header class="mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">ShenWan Studio Process Assets</h1>
        <p class="text-gray-500 text-lg">
          沉淀的项目管理模板、效率工具与备考资料，欢迎自取。
        </p>
      </header>

      {
        resourceData.map((section) => (
          <div class="mb-12">
            <h2 class="text-xl font-semibold text-gray-700 mb-6 flex items-center">
              <span class="w-1.5 h-6 bg-blue-500 rounded-full mr-3" />
              {section.category}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {section.items.map((item) => (
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex flex-col h-full hover:shadow-md transition-shadow">
                  
                  {/* --- 修复后的标题区域：图标与文字完美居中 --- */}
                  <div class="flex items-center gap-3 mb-3">
                    {item.type === "public" ? (
                      /* 公开资源图标：蓝色 */
                      <div class="shrink-0 w-9 h-9 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                        </svg>
                      </div>
                    ) : (
                      /* 引流资源图标：绿色 */
                      <div class="shrink-0 w-9 h-9 bg-green-50 rounded-xl flex items-center justify-center text-[#07c160]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H7a2 2 0 01-2-2v-8z"></path>
                        </svg>
                      </div>
                    )}
                    <h3 class="text-lg font-bold text-gray-900 leading-tight">
                      {item.title}
                    </h3>
                  </div>

                  <p class="text-sm text-gray-500 line-clamp-2 mb-4 flex-grow px-1">
                    {item.desc}
                  </p>

                  <div class="flex gap-2 mb-6 px-1">
                    {item.tags.map((tag) => (
                      <span class="bg-blue-50 text-blue-600 text-xs px-2.5 py-1 rounded-md font-medium">
                        {tag}
                      </span>
                    ))}
                  </div>

                  {item.type === "public" ? (
                    /* --- 形态 A：直接公开网盘的资源 --- */
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 mt-auto">
                      <div class="text-xs text-gray-600 mb-2 truncate">
                        <span class="font-medium text-gray-800">链接：</span>
                        <a
                          href={item.link}
                          target="_blank"
                          class="text-blue-500 hover:underline"
                        >
                          {item.link}
                        </a>
                      </div>
                      <div class="text-xs text-gray-600 mb-4 text-center">
                        <span class="font-medium text-gray-800">提取码：</span>
                        <code class="bg-white border border-gray-200 px-2 py-0.5 rounded text-gray-800 font-mono font-bold">
                          {item.code}
                        </code>
                      </div>

                      <button
                        class="copy-btn w-full bg-gray-900 hover:bg-gray-800 text-white text-sm font-medium py-2 rounded-lg transition-colors flex justify-center items-center gap-2"
                        data-link={item.link}
                        data-code={item.code}
                      >
                        <svg class="w-4 h-4 icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                        <span class="btn-text">复制链接与密码</span>
                      </button>
                    </div>
                  ) : (
                    /* --- 形态 B：需要公众号引流的资源 --- */
                    <div class="mt-auto">
                      <button
                        class="wechat-btn w-full bg-[#07c160] hover:bg-[#06ad56] text-white text-sm font-medium py-3 rounded-xl transition-colors flex justify-center items-center gap-2 shadow-sm"
                        data-keyword={item.keyword}
                      >
                        <svg class="w-5 h-5 shrink-0" viewBox="0 0 1024 1024" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                          <path d="M682.667 426.667c29.866 0 55.466 2.133 81.066 8.533C718.933 300.8 554.667 192 362.667 192 162.133 192 0 326.4 0 490.667c0 93.867 51.2 177.067 132.267 236.8l-34.134 102.4 119.467-59.733c44.8 12.8 91.733 19.2 142.933 19.2 12.8 0 27.733 0 40.534-2.133-12.8-29.867-21.334-61.867-21.334-93.867 0-147.2 134.4-266.667 302.934-266.667zM256 362.667c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm213.333 0c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm554.667 277.333c0-115.2-115.2-209.067-256-209.067s-256 93.867-256 209.067 115.2 209.067 256 209.067c38.4 0 74.667-8.533 108.8-21.333l89.6 44.8-25.6-76.8c53.333-42.667 83.2-96 83.2-155.734zm-341.333-32c-17.067 0-32-14.934-32-32s14.933-32 32-32 32 14.934 32 32-14.933 32-32 32zm170.666 0c-17.066 0-32-14.934-32-32s14.934-32 32-32 32 14.934 32 32-14.934 32-32 32z" />
                        </svg>
                        点击获取下载地址
                      </button>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    {/* 公众号弹窗 */}
    <div id="wechat-modal" class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center">
      <div id="wechat-modal-content" class="bg-white rounded-2xl p-8 max-w-sm w-full mx-4 shadow-2xl modal-enter text-center relative">
        <button id="close-wechat-modal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-[#07c160] shrink-0" viewBox="0 0 1024 1024" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M682.667 426.667c29.866 0 55.466 2.133 81.066 8.533C718.933 300.8 554.667 192 362.667 192 162.133 192 0 326.4 0 490.667c0 93.867 51.2 177.067 132.267 236.8l-34.134 102.4 119.467-59.733c44.8 12.8 91.733 19.2 142.933 19.2 12.8 0 27.733 0 40.534-2.133-12.8-29.867-21.334-61.867-21.334-93.867 0-147.2 134.4-266.667 302.934-266.667zM256 362.667c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm213.333 0c-23.467 0-42.667-19.2-42.667-42.667s19.2-42.667 42.667-42.667 42.667 19.2 42.667 42.667-19.2 42.667-42.667 42.667zm554.667 277.333c0-115.2-115.2-209.067-256-209.067s-256 93.867-256 209.067 115.2 209.067 256 209.067c38.4 0 74.667-8.533 108.8-21.333l89.6 44.8-25.6-76.8c53.333-42.667 83.2-96 83.2-155.734zm-341.333-32c-17.067 0-32-14.934-32-32s14.933-32 32-32 32 14.934 32 32-14.933 32-32 32zm170.666 0c-17.066 0-32-14.934-32-32s14.934-32 32-32 32 14.934 32 32-14.934 32-32 32z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">获取下载链接</h3>
        <p class="text-sm text-gray-500 mb-6">微信扫码关注公众号，回复关键字自动获取网盘链接与提取码。</p>
        <img src="/images/mp_qr.jpg" alt="公众号二维码" class="w-48 h-48 mx-auto border border-gray-100 rounded-lg shadow-sm mb-6" />
        <div class="bg-gray-50 rounded-lg py-3 px-4 inline-block border border-gray-100">
          <span class="text-gray-500 text-sm">回复关键字：</span>
          <span id="modal-keyword-display" class="font-bold text-[#07c160] text-lg tracking-wide ml-1"></span>
        </div>
      </div>
    </div>

    <script is:inline>
      /* --- 复制逻辑 --- */
      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const link = this.getAttribute("data-link");
          const code = this.getAttribute("data-code");
          const textSpan = this.querySelector(".btn-text");
          const textToCopy = `链接：${link}\n提取码：${code}`;

          try {
            await navigator.clipboard.writeText(textToCopy);
            this.classList.replace("bg-gray-900", "bg-green-500");
            textSpan.innerText = "复制成功！";
            setTimeout(() => {
              this.classList.replace("bg-green-500", "bg-gray-900");
              textSpan.innerText = "复制链接与密码";
            }, 2000);
          } catch (err) { alert("复制失败"); }
        });
      });

      /* --- 弹窗逻辑 --- */
      const wechatModal = document.getElementById("wechat-modal");
      const wechatModalContent = document.getElementById("wechat-modal-content");
      const closeWechatBtn = document.getElementById("close-wechat-modal");
      const keywordDisplay = document.getElementById("modal-keyword-display");

      document.querySelectorAll(".wechat-btn").forEach((btn) => {
        btn.addEventListener("click", function () {
          keywordDisplay.innerText = this.getAttribute("data-keyword");
          wechatModal.classList.remove("hidden");
          requestAnimationFrame(() => wechatModalContent.classList.add("modal-enter-active"));
        });
      });

      const closeWechatModal = () => {
        wechatModalContent.classList.remove("modal-enter-active");
        setTimeout(() => wechatModal.classList.add("hidden"), 300);
      };

      closeWechatBtn.addEventListener("click", closeWechatModal);
      wechatModal.addEventListener("click", (e) => { if (e.target === wechatModal) closeWechatModal(); });
    </script>
  </body>
</html>