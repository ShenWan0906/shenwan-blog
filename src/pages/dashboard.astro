---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="仪表盘" description="系统运行状态监控">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 sm:px-6 py-6 relative w-full flex flex-col gap-6 bg-transparent">
      
      {/* --- 1. 顶部全景控制台 --- */}
      <div class="relative w-full rounded-3xl p-6 sm:p-8 overflow-hidden bg-gradient-to-br from-blue-600 via-indigo-600 to-cyan-500 text-white shadow-lg shadow-blue-500/20 group flex flex-col justify-between min-h-[180px]">
        <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
        <div class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-white/10 blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-cyan-400/20 blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>

        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-6">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-md border border-white/20 shadow-inner">
              <i class="fa-solid fa-server text-2xl animate-pulse"></i>
            </div>
            <div class="flex flex-col">
              <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-blue-100 drop-shadow-sm">
                核心控制台
              </h1>
              <div class="flex items-center gap-2 text-xs font-mono mt-1 tracking-wider text-blue-100/80">
                <span class="w-2 h-2 rounded-full bg-green-400 shadow-[0_0_8px_#4ade80] animate-pulse"></span>
                SYSTEM ONLINE v2.0
              </div>
            </div>
          </div>

          <div class="text-right flex flex-col items-end">
            <div id="clock" class="text-4xl md:text-5xl font-mono font-black tracking-widest text-white drop-shadow-[0_2px_10px_rgba(0,0,0,0.3)]">
              00:00:00
            </div>
            <div id="date" class="text-xs md:text-sm font-medium opacity-80 uppercase tracking-[0.2em] mt-2 border-b border-white/20 pb-1">
              LOADING DATE
            </div>
          </div>
        </div>

        <div class="relative z-10 w-fit bg-black/20 border border-white/10 backdrop-blur-md rounded-2xl p-3 flex items-center gap-3 hover:bg-black/30 transition-colors">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-tr from-pink-500 to-orange-400 flex items-center justify-center shadow-lg">
            <i class="fa-solid fa-robot text-xs"></i>
          </div>
          <div class="flex flex-col pr-4">
            <span class="text-[10px] text-white/60 uppercase tracking-widest font-semibold mb-0.5">Status Report</span>
            <div id="greeting" class="text-sm font-bold tracking-wide">
              正在连接神经网络...
            </div>
          </div>
        </div>
      </div>

      {/* --- 2. 核心数据六宫格 --- */}
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        
        <div class="bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
          <div class="absolute -right-6 -top-6 text-8xl opacity-[0.03] dark:opacity-[0.02] group-hover:rotate-12 transition-transform duration-500"><i class="fa-solid fa-eye"></i></div>
          <div class="text-zinc-500 dark:text-zinc-400 font-bold text-xs uppercase tracking-widest flex items-center gap-2">
            <i class="fa-solid fa-fire text-red-500"></i> 总访问量 (PV)
          </div>
          <div class="text-4xl font-mono font-black text-zinc-800 dark:text-zinc-100 mt-2 tracking-tighter">
            <span id="busuanzi_value_site_pv" class="count-up">0</span>
          </div>
          <div class="text-xs text-zinc-400 font-medium mt-auto flex justify-between items-center">
            <span>来自全网流量</span>
            <span class="text-red-500 bg-red-500/10 px-1.5 py-0.5 rounded text-[10px]">+🔥</span>
          </div>
        </div>

        <div class="bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-xl transition-all duration-300 relative overflow-hidden group">
          <div class="absolute -right-6 -top-6 text-8xl opacity-[0.03] dark:opacity-[0.02] group-hover:-rotate-12 transition-transform duration-500"><i class="fa-solid fa-user-astronaut"></i></div>
          <div class="text-zinc-500 dark:text-zinc-400 font-bold text-xs uppercase tracking-widest flex items-center gap-2">
            <i class="fa-solid fa-users text-emerald-500"></i> 独立访客 (UV)
          </div>
          <div class="text-4xl font-mono font-black text-zinc-800 dark:text-zinc-100 mt-2 tracking-tighter">
            <span id="busuanzi_value_site_uv" class="count-up">0</span>
          </div>
          <div class="text-xs text-zinc-400 font-medium mt-auto flex justify-between items-center">
            <span>独立IP统计</span>
            <span class="text-emerald-500 bg-emerald-500/10 px-1.5 py-0.5 rounded text-[10px]">Active</span>
          </div>
        </div>

        <a 
          href="https://github.com/ShenWan0906/MyBlog" 
          target="_blank" 
          rel="noopener noreferrer"
          class="group bg-gradient-to-br from-orange-50 to-amber-50 dark:from-orange-900/10 dark:to-amber-900/10 border border-orange-100 dark:border-orange-900/20 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-orange-500/20 transition-all duration-300 relative overflow-hidden cursor-pointer block"
        >
          <div class="transition-opacity duration-300 group-hover:opacity-20 h-full flex flex-col justify-between">
            <div class="text-orange-600 dark:text-orange-400 font-bold text-xs uppercase tracking-widest flex items-center gap-2">
              <i class="fa-solid fa-book-journal-whills"></i> 内容仓库
            </div>
            <div>
              <div class="flex items-baseline gap-1 mt-2">
                <span id="article-count" class="text-4xl font-mono font-black text-orange-600 dark:text-orange-400 tracking-tighter">0</span>
                <span class="text-sm font-bold text-orange-500/60 uppercase">Posts</span>
              </div>
              <div class="w-full bg-orange-200 dark:bg-orange-900/50 h-1.5 rounded-full mt-2 overflow-hidden">
                <div class="bg-orange-500 h-full rounded-full" style="width: 78%"></div>
              </div>
            </div>
            <div class="text-xs text-orange-500/80 font-medium mt-auto flex gap-3">
              <span>7 分类</span>
              <span>7 标签</span>
            </div>
          </div>

          <div class="absolute inset-0 bg-black/40 dark:bg-black/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center z-10">
            <div class="flex items-center gap-2 bg-white text-zinc-900 px-4 py-2.5 rounded-xl font-bold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 shadow-xl">
              <i class="fa-brands fa-github text-lg"></i>
              去 GitHub 看看
            </div>
          </div>
        </a>

        <div class="bg-gradient-to-br from-cyan-50 to-blue-50 dark:from-cyan-900/10 dark:to-blue-900/10 border border-cyan-100 dark:border-cyan-900/20 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-cyan-500/10 transition-all duration-300">
          <div class="text-cyan-600 dark:text-cyan-400 font-bold text-xs uppercase tracking-widest flex items-center justify-between">
            <span class="flex items-center gap-2"><i class="fa-solid fa-wifi"></i> 网络链路</span>
            <span id="net-type" class="bg-cyan-500/10 px-1.5 py-0.5 rounded text-[10px]">WIFI</span>
          </div>
          <div class="flex items-baseline gap-2 mt-2">
            <span id="net-ping" class="text-4xl font-mono font-black text-cyan-600 dark:text-cyan-400 tracking-tighter">--</span>
            <span class="text-sm font-bold text-cyan-500/60 uppercase">ms</span>
          </div>
          <div class="flex items-end gap-1 h-4 mt-2 opacity-50">
            <div class="w-1 bg-cyan-500 rounded-t-sm h-full animate-[bounce_1s_infinite_0.1s]"></div>
            <div class="w-1 bg-cyan-500 rounded-t-sm h-2/3 animate-[bounce_1s_infinite_0.2s]"></div>
            <div class="w-1 bg-cyan-500 rounded-t-sm h-1/2 animate-[bounce_1s_infinite_0.3s]"></div>
            <div class="w-1 bg-cyan-500 rounded-t-sm h-4/5 animate-[bounce_1s_infinite_0.4s]"></div>
            <div class="w-1 bg-cyan-500 rounded-t-sm h-1/3 animate-[bounce_1s_infinite_0.5s]"></div>
          </div>
          <div class="text-xs text-cyan-500/80 font-medium mt-auto">
            连接稳定，无丢包
          </div>
        </div>

        <div class="bg-gradient-to-br from-violet-50 to-purple-50 dark:from-violet-900/10 dark:to-purple-900/10 border border-violet-100 dark:border-violet-900/20 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-violet-500/10 transition-all duration-300">
          <div class="text-violet-600 dark:text-violet-400 font-bold text-xs uppercase tracking-widest flex items-center gap-2">
            <i class="fa-solid fa-rocket"></i> 稳定运行
          </div>
          <div class="flex items-baseline gap-1 mt-2">
            <span id="run-days" class="text-4xl font-mono font-black text-violet-600 dark:text-violet-400 tracking-tighter">0</span>
            <span class="text-sm font-bold text-violet-500/60 uppercase">Days</span>
          </div>
          <div class="text-xs text-violet-500/80 font-medium mt-auto font-mono bg-violet-500/10 w-fit px-2 py-1 rounded-md" id="start-date-display">
            Since 2023
          </div>
        </div>

        <div class="bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 p-5 rounded-3xl flex flex-col justify-between h-36 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
          <div class="text-zinc-500 dark:text-zinc-400 font-bold text-xs uppercase tracking-widest flex items-center gap-2">
            <i class="fa-solid fa-desktop"></i> 访问设备探针
          </div>
          <div class="flex flex-col gap-1.5 mt-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-zinc-500">OS</span>
              <span id="user-os" class="text-sm font-bold text-zinc-800 dark:text-zinc-200 text-right">Detecting...</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-zinc-500">Browser</span>
              <span id="user-browser" class="text-sm font-bold text-zinc-800 dark:text-zinc-200 text-right">...</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-zinc-500">Screen</span>
              <span id="user-screen" class="text-xs font-mono font-bold text-zinc-800 dark:text-zinc-200 text-right">...</span>
            </div>
          </div>
        </div>
      </div>

      {/* --- 3. 图表区域：流量与雷达 --- */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 h-auto min-h-[350px]">
        <div class="md:col-span-2 bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 rounded-3xl p-6 flex flex-col relative overflow-hidden">
          <div class="flex justify-between items-center mb-4 z-10">
            <div>
              <h3 class="text-sm font-bold text-zinc-800 dark:text-zinc-200 uppercase tracking-widest flex items-center gap-2">
                <i class="fa-solid fa-chart-line text-blue-500"></i> 实时流量监测
              </h3>
              <p class="text-[10px] text-zinc-500 mt-1 font-mono">INBOUND / OUTBOUND SIMULATION</p>
            </div>
            <div class="flex gap-2 items-center bg-black/5 dark:bg-white/5 px-3 py-1 rounded-full border border-black/5 dark:border-white/10">
              <span class="flex h-2 w-2 relative">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              <span class="text-xs text-zinc-600 dark:text-zinc-300 font-bold tracking-widest">LIVE</span>
            </div>
          </div>
          <div id="traffic-chart" class="w-full h-full min-h-[250px] z-10"></div>
        </div>

        <div class="bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 rounded-3xl p-6 flex flex-col">
          <h3 class="text-sm font-bold text-zinc-800 dark:text-zinc-200 uppercase tracking-widest mb-1 text-center flex items-center justify-center gap-2">
            <i class="fa-solid fa-crosshairs text-indigo-500"></i> 综合维度分析
          </h3>
          <p class="text-[10px] text-zinc-500 mb-2 font-mono text-center">SYSTEM CAPABILITY MATRIX</p>
          <div id="radar-chart" class="w-full h-full min-h-[250px]"></div>
        </div>
      </div>

      {/* --- 4. 新增：创作热力图 (GitHub Style) --- */}
      <div class="bg-white/50 dark:bg-zinc-900/50 border border-black/5 dark:border-white/5 rounded-3xl p-6 flex flex-col mt-2 relative overflow-x-auto custom-scrollbar">
        <div class="flex justify-between items-center mb-6 min-w-[700px]">
          <div>
            <h3 class="text-sm font-bold text-zinc-800 dark:text-zinc-200 uppercase tracking-widest flex items-center gap-2">
              <i class="fa-solid fa-calendar-days text-orange-500"></i> 创作热力图
            </h3>
            <p class="text-[10px] text-zinc-500 mt-1 font-mono">ANNUAL WRITING FREQUENCY</p>
          </div>
          <div class="flex items-center gap-2 text-[10px] font-bold text-zinc-500 dark:text-zinc-400">
            <span>Less</span>
            <div class="flex gap-1">
              {/* 深浅模式图例 */}
              <div class="w-3 h-3 rounded-sm bg-zinc-100 dark:bg-zinc-800"></div>
              <div class="w-3 h-3 rounded-sm bg-orange-200 dark:bg-orange-900/40"></div>
              <div class="w-3 h-3 rounded-sm bg-orange-300 dark:bg-orange-700/60"></div>
              <div class="w-3 h-3 rounded-sm bg-orange-400 dark:bg-orange-600/80"></div>
              <div class="w-3 h-3 rounded-sm bg-orange-500 dark:bg-orange-500"></div>
            </div>
            <span>More</span>
          </div>
        </div>
        {/* 热力图容器 */}
        <div id="heatmap-chart" class="w-full min-w-[700px] h-[180px]"></div>
      </div>

    </div>
  </div>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

  <script is:inline>
    {
      const START_DATE = "2025-02-03"; 
      const TOTAL_ARTICLES = 100;      
      
      let clockInterval;
      let chartInterval;
      let networkInterval;

      // ====== 辅助动画：数字平滑滚动 ======
      const animateValue = (id, start, end, duration) => {
        const obj = document.getElementById(id);
        if(!obj) return;
        let startTimestamp = null;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          obj.innerHTML = Math.floor(progress * (end - start) + start);
          if (progress < 1) {
            window.requestAnimationFrame(step);
          }
        };
        window.requestAnimationFrame(step);
      };

      const initBasicFeatures = () => {
        setTimeout(() => animateValue("article-count", 0, TOTAL_ARTICLES, 2000), 500); 

        const updateTime = () => {
          const now = new Date();
          const hour = now.getHours();
          const greetingEl = document.getElementById("greeting");
          const clockEl = document.getElementById("clock");
          const dateEl = document.getElementById("date");

          if (clockEl) clockEl.innerText = now.toLocaleTimeString("en-GB", { hour12: false });
          if (dateEl) dateEl.innerText = now.toLocaleDateString("en-US", { weekday: "short", year: "numeric", month: "short", day: "numeric" });

          let greet = "Hello!";
          if (hour < 5) greet = "深夜运转，注意服务器温控 🌙";
          else if (hour < 9) greet = "晨间自检完成，一切正常 ☀️";
          else if (hour < 12) greet = "上午好，流量峰值即将到来 ☕";
          else if (hour < 14) greet = "中午好，已开启节能模式 🍱";
          else if (hour < 18) greet = "下午好，防火墙运行平稳 🛡️";
          else if (hour < 22) greet = "晚上好，准备执行定时备份 📦";
          else greet = "夜间模式已激活 🌌";

          if (greetingEl) greetingEl.innerText = greet;
        };

        if (clockInterval) clearInterval(clockInterval);
        clockInterval = setInterval(updateTime, 1000);
        updateTime();

        const start = new Date(START_DATE);
        const diff = new Date() - start;
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        animateValue("run-days", 0, days, 2000);
        document.getElementById("start-date-display").innerText = `Since ${START_DATE}`;

        const ua = navigator.userAgent;
        let os = "Unknown OS";
        if (ua.includes("Win")) os = "Windows";
        if (ua.includes("Mac")) os = "macOS";
        if (ua.includes("Linux")) os = "Linux";
        if (ua.includes("Android")) os = "Android";
        if (ua.includes("iPhone") || ua.includes("iPad")) os = "iOS";

        let browser = "Unknown Browser";
        if (ua.includes("Chrome")) browser = "Chrome";
        if (ua.includes("Firefox")) browser = "Firefox";
        if (ua.includes("Safari") && !ua.includes("Chrome")) browser = "Safari";
        if (ua.includes("Edg")) browser = "Edge";

        document.getElementById("user-os").innerText = os;
        document.getElementById("user-browser").innerText = browser;
        document.getElementById("user-screen").innerText = `${window.screen.width} × ${window.screen.height}`;

        const updateNetwork = () => {
          const pingEl = document.getElementById("net-ping");
          const typeEl = document.getElementById("net-type");
          if(pingEl) {
            const ping = Math.floor(Math.random() * 23) + 12; 
            pingEl.innerText = ping;
            pingEl.className = ping > 30 
              ? "text-4xl font-mono font-black text-orange-500 tracking-tighter" 
              : "text-4xl font-mono font-black text-cyan-600 dark:text-cyan-400 tracking-tighter";
          }
          if(typeEl && navigator.connection) {
             typeEl.innerText = navigator.connection.effectiveType.toUpperCase() || 'WIFI';
          }
        };
        if(networkInterval) clearInterval(networkInterval);
        networkInterval = setInterval(updateNetwork, 2500);
        updateNetwork();
      };

      initBasicFeatures();

      // ================= 图表增强逻辑 =================
      const initCharts = () => {
        const trafficDom = document.getElementById("traffic-chart");
        const radarDom = document.getElementById("radar-chart");
        const heatmapDom = document.getElementById("heatmap-chart"); // 获取热力图容器
        
        if (!trafficDom || !radarDom || !heatmapDom) return;

        const isDark = document.documentElement.classList.contains('dark');

        // --- 1. 双线流量图 ---
        const trafficChart = echarts.getInstanceByDom(trafficDom) || echarts.init(trafficDom);
        let dataIn = Array.from({ length: 20 }, () => Math.floor(Math.random() * 50) + 20);
        let dataOut = Array.from({ length: 20 }, () => Math.floor(Math.random() * 30) + 10);
        
        trafficChart.setOption({
          grid: { top: 10, right: 0, bottom: 0, left: 0 },
          tooltip: { 
            trigger: "axis", 
            backgroundColor: isDark ? 'rgba(0,0,0,0.8)' : 'rgba(255,255,255,0.9)', 
            textStyle: {color: isDark ? '#fff' : '#000'},
            borderWidth: 0,
            formatter: "请求: {c0} /s<br/>响应: {c1} /s" 
          },
          xAxis: { type: "category", show: false, boundaryGap: false },
          yAxis: { type: "value", show: false, min: 0, max: 100 },
          series: [
            {
              name: "Inbound", type: "line", smooth: 0.4, symbol: 'none', data: dataIn,
              lineStyle: { width: 3, color: '#3b82f6' },
              areaStyle: {
                color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                  { offset: 0, color: "rgba(59, 130, 246, 0.4)" }, { offset: 1, color: "rgba(59, 130, 246, 0.0)" }
                ])
              }
            },
            {
              name: "Outbound", type: "line", smooth: 0.4, symbol: 'none', data: dataOut,
              lineStyle: { width: 3, color: '#10b981' },
              areaStyle: {
                color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                  { offset: 0, color: "rgba(16, 185, 129, 0.4)" }, { offset: 1, color: "rgba(16, 185, 129, 0.0)" }
                ])
              }
            }
          ]
        });

        if (chartInterval) clearInterval(chartInterval);
        chartInterval = setInterval(() => {
          if (!document.getElementById("traffic-chart")) return;
          dataIn.shift(); dataIn.push(Math.floor(Math.random() * 50) + 20);
          dataOut.shift(); dataOut.push(Math.floor(Math.random() * 30) + 10);
          trafficChart.setOption({ series: [{ data: dataIn }, { data: dataOut }] });
        }, 2000);

        // --- 2. 科技感雷达图 ---
        const radarChart = echarts.getInstanceByDom(radarDom) || echarts.init(radarDom);
        const radarColor = isDark ? '#a1a1aa' : '#52525b';
        
        radarChart.setOption({
          tooltip: { show: true, backgroundColor: isDark ? 'rgba(0,0,0,0.8)' : 'rgba(255,255,255,0.9)', textStyle: {color: isDark ? '#fff' : '#000'}, borderWidth: 0 },
          radar: {
            indicator: [
              { name: "硬核代码", max: 100 }, { name: "写作排版", max: 100 }, { name: "更新频率", max: 100 },
              { name: "站点性能", max: 100 }, { name: "设计审美", max: 100 }
            ],
            radius: '65%', splitNumber: 4,
            axisName: { color: radarColor, fontSize: 11, fontWeight: 'bold' },
            splitLine: { lineStyle: { color: isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.05)' } },
            splitArea: { show: false },
            axisLine: { lineStyle: { color: isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.05)' } }
          },
          series: [{
            type: "radar", symbol: 'circle', symbolSize: 6,
            itemStyle: { color: '#6366f1' }, lineStyle: { width: 2 },
            areaStyle: { color: "rgba(99, 102, 241, 0.3)" },
            data: [{ value: [90, 85, 75, 95, 88], name: "当前属性" }]
          }]
        });

        // --- 3. 创作热力图 (GitHub Style) ---
        const heatmapChart = echarts.getInstanceByDom(heatmapDom) || echarts.init(heatmapDom);
        
        // 生成模拟数据：过去 365 天的文章分布
        const getHeatmapData = () => {
            const data = [];
            const endDate = new Date();
            const startDate = new Date(endDate.getTime() - 365 * 24 * 3600 * 1000);
            
            for (let time = startDate.getTime(); time <= endDate.getTime(); time += 86400000) {
                // 模拟数据：大约20%的日子有更新，更新数量在1-4之间
                const count = Math.random() > 0.8 ? Math.floor(Math.random() * 4) + 1 : 0;
                data.push([
                    echarts.format.formatTime('yyyy-MM-dd', time),
                    count
                ]);
            }
            return data;
        };

        const startDateStr = echarts.format.formatTime('yyyy-MM-dd', new Date(new Date().getTime() - 365 * 24 * 3600 * 1000));
        const endDateStr = echarts.format.formatTime('yyyy-MM-dd', new Date());
        
        // 配色方案适配深浅模式
        const emptyCellColor = isDark ? '#27272a' : '#f4f4f5'; // zinc-800 / zinc-100
        const borderColor = isDark ? '#18181b' : '#ffffff';    // 背景色作为边框分割
        
        heatmapChart.setOption({
            tooltip: {
                position: 'top',
                formatter: function (p) {
                    const count = p.data[1];
                    const text = count === 0 ? 'No posts' : `${count} posts`;
                    return `<div style="font-size:12px">${text} on ${p.data[0]}</div>`;
                },
                backgroundColor: isDark ? 'rgba(0,0,0,0.8)' : 'rgba(255,255,255,0.9)',
                textStyle: { color: isDark ? '#fff' : '#000' },
                borderWidth: 0,
                padding: [4, 8]
            },
            visualMap: {
                show: false,
                min: 0,
                max: 4,
                inRange: {
                    // 与 HTML 结构中展示的图例颜色保持一致 (Orange theme)
                    color: isDark 
                      ? [emptyCellColor, 'rgba(124, 45, 18, 0.4)', 'rgba(194, 65, 12, 0.6)', 'rgba(234, 88, 12, 0.8)', '#f97316'] 
                      : [emptyCellColor, '#fbd38d', '#f6ad55', '#ed8936', '#f97316']
                }
            },
            calendar: {
                top: 20,
                left: 30,
                right: 10,
                bottom: 10,
                cellSize: ['auto', 14], // 高度固定，宽度自动以充满容器
                range: [startDateStr, endDateStr],
                itemStyle: {
                    color: emptyCellColor,
                    borderWidth: 3,
                    borderColor: borderColor,
                    borderRadius: 2
                },
                splitLine: { show: false }, // 不显示月份分割线，更像 GitHub
                yearLabel: { show: false },
                monthLabel: {
                    nameMap: 'EN',
                    color: isDark ? '#a1a1aa' : '#71717a',
                    fontSize: 10,
                    margin: 5
                },
                dayLabel: {
                    firstDay: 1,
                    nameMap: ['S', 'M', 'T', 'W', 'T', 'F', 'S'],
                    color: isDark ? '#a1a1aa' : '#71717a',
                    fontSize: 10
                }
            },
            series: {
                type: 'heatmap',
                coordinateSystem: 'calendar',
                data: getHeatmapData()
            }
        });

        // 监听窗口大小变化重新渲染
        window.addEventListener("resize", () => {
          trafficChart.resize();
          radarChart.resize();
          heatmapChart.resize();
        });
      };

      const loadECharts = () => {
        if (window.echarts) {
          initCharts();
          return;
        }
        if (document.getElementById("echarts-script")) return;
        const script = document.createElement("script");
        script.id = "echarts-script";
        script.src = "https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js";
        script.onload = initCharts;
        document.head.appendChild(script);
      };

      loadECharts();
    }
  </script>
  
  <style>
    /* 隐藏横向滚动条，但保留滚动功能（适配小屏幕） */
    .custom-scrollbar::-webkit-scrollbar {
        height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(156, 163, 175, 0.3);
        border-radius: 10px;
    }
  </style>
</MainGridLayout>