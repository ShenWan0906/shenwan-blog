---
// src/pages/universe.astro
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>知识图谱 | ShenWan Studio</title>
  <style>
    /* 1. 全局容器拦截，防止污染博客白色主背景 */
    .graph-wrapper {
      position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
      background-color: #030712; overflow: hidden; z-index: 50;
      font-family: system-ui, -apple-system, sans-serif;
    }
    #graph-container { width: 100%; height: 100%; }
    
    /* 2. 左上角基础 UI */
    .overlay {
      position: absolute; top: 30px; left: 30px; z-index: 60;
      color: rgba(255, 255, 255, 0.9); pointer-events: none;
    }
    .overlay h1 { margin: 0 0 5px 0; font-size: 28px; font-weight: 700; letter-spacing: 2px; text-shadow: 0 0 20px rgba(255,255,255,0.3); }
    .overlay p { margin: 0; font-size: 13px; color: rgba(255,255,255,0.5); }

    /* 3. 核心：毛玻璃全息侧边栏 */
    #info-sidebar {
      position: absolute; top: 0; right: -400px; /* 初始隐藏在屏幕右侧 */
      width: 380px; height: 100vh;
      background: rgba(15, 23, 42, 0.6); 
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
      z-index: 100; padding: 40px 30px; box-sizing: border-box;
      transition: right 0.5s cubic-bezier(0.16, 1, 0.3, 1); /* 丝滑的滑出动画 */
      display: flex; flex-direction: column;
      color: #f8fafc;
    }
    #info-sidebar.active { right: 0; } /* 激活时滑入 */

    /* 侧边栏内部元素样式 */
    .close-btn {
      align-self: flex-end; background: none; border: none; color: #94a3b8;
      font-size: 28px; cursor: pointer; transition: color 0.2s; margin-bottom: 20px;
    }
    .close-btn:hover { color: #fff; }
    
    #side-type { font-size: 12px; color: #34d399; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
    #side-title { font-size: 22px; font-weight: 600; line-height: 1.4; margin: 0 0 20px 0; }
    #side-desc { font-size: 14px; color: #cbd5e1; line-height: 1.6; flex-grow: 1; }
    
    .read-btn {
      display: block; width: 100%; padding: 14px 0; text-align: center;
      background: linear-gradient(135deg, #3b82f6, #2563eb);
      color: #fff; text-decoration: none; border-radius: 8px;
      font-size: 15px; font-weight: 600; letter-spacing: 1px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .read-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4); }
  </style>
</head>
<body>
  <div class="graph-wrapper">
    <div class="overlay">
      <h1>知识图谱</h1>
      <p>拖拽旋转星系 | 滚轮缩放 | 点击繁星探索</p>
    </div>

    <div id="graph-container"></div>

    <div id="info-sidebar">
      <button class="close-btn" id="close-sidebar">×</button>
      <div id="side-type">Article</div>
      <h2 id="side-title">标题加载中...</h2>
      <p id="side-desc">在这里，我们将探索项目管理与技术开发的深度融合，以及藏在历史脉络中的管理智慧。</p>
      <a href="#" id="side-link" class="read-btn">开启阅读之旅 ➔</a>
    </div>
  </div>

  <script type="module">
    import * as THREE from 'https://esm.sh/three';
    import ForceGraph3D from 'https://esm.sh/3d-force-graph';
    import SpriteText from 'https://esm.sh/three-spritetext';

    const container = document.getElementById('graph-container');
    const sidebar = document.getElementById('info-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    let Graph;

    // 侧边栏关闭逻辑：滑出并重置镜头
    closeBtn.addEventListener('click', () => {
      sidebar.classList.remove('active');
      Graph.cameraPosition({ z: 250 }, { x: 0, y: 0, z: 0 }, 1500); // 镜头退回全景
    });

    // 创建发光纹理函数
    function createGlowTexture(colorRGB) {
      const canvas = document.createElement('canvas');
      canvas.width = 128; canvas.height = 128;
      const ctx = canvas.getContext('2d');
      const gradient = ctx.createRadialGradient(64, 64, 0, 64, 64, 64);
      gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
      gradient.addColorStop(0.2, colorRGB);
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, 128, 128);
      return new THREE.CanvasTexture(canvas);
    }

    const textureCategory = createGlowTexture('rgba(251, 191, 36, 1)');
    const textureTag = createGlowTexture('rgba(52, 211, 153, 1)');
    const texturePost = createGlowTexture('rgba(148, 163, 184, 0.8)');

    fetch('/api/graph-data.json')
      .then(res => res.json())
      .then(data => {
        Graph = ForceGraph3D()(container)
          .graphData(data)
          .backgroundColor('#030712')
          .nodeId('id')
          .nodeLabel(node => node.type === 'post' ? node.name : '')
          
          .nodeThreeObject(node => {
            const group = new THREE.Group();
            let texture, size;
            
            if (node.type === 'category') { texture = textureCategory; size = 20; }
            else if (node.type === 'tag') { texture = textureTag; size = 12; }
            else { texture = texturePost; size = 6; }

            const material = new THREE.SpriteMaterial({ 
              map: texture, color: 0xffffff, transparent: true, 
              blending: THREE.AdditiveBlending, depthWrite: false 
            });
            const sprite = new THREE.Sprite(material);
            sprite.scale.set(size, size, 1);
            group.add(sprite);

            if (node.type === 'category' || node.type === 'tag') {
              const spriteText = new SpriteText(node.name);
              spriteText.color = node.type === 'category' ? '#fbbf24' : '#34d399';
              spriteText.textHeight = node.type === 'category' ? 4 : 2.5;
              spriteText.fontWeight = 'bold';
              spriteText.position.y = -(size / 2) - 2;
              group.add(spriteText);
            }
            return group;
          })
          
          .linkColor(() => 'rgba(255,255,255,0.06)')
          .linkWidth(0.5)
          .linkDirectionalParticles(2)
          .linkDirectionalParticleWidth(1.2)
          .linkDirectionalParticleSpeed(0.006)
          
          // --- 核心交互更新 ---
          .onNodeClick(node => {
            // 1. 镜头推进数学计算
            const distance = 60;
            const distRatio = 1 + distance / Math.hypot(node.x, node.y, node.z);
            const newPos = node.x || node.y || node.z
              ? { x: node.x * distRatio, y: node.y * distRatio, z: node.z * distRatio }
              : { x: 0, y: 0, z: distance };
            
            // 执行平滑摄像机飞行
            Graph.cameraPosition(newPos, node, 1500);

            // 2. 侧边栏呼出与数据绑定逻辑
            if (node.type === 'post') {
              document.getElementById('side-title').innerText = node.name;
              
              // 👇 核心改动：把后端的摘要绑定到侧边栏，加入优雅的容错文案
              const defaultDesc = '在这里，我们将探索项目管理与技术开发的深度融合，以及藏在历史脉络中的管理智慧。';
              document.getElementById('side-desc').innerText = node.description || defaultDesc;
              // 👆
              
              document.getElementById('side-link').href = `/posts/${node.id}/`;
              sidebar.classList.add('active'); 
            } else {
              sidebar.classList.remove('active');
            }
          });

        Graph.cameraPosition({ z: 250 });

        window.addEventListener('resize', () => {
          Graph.width(window.innerWidth);
          Graph.height(window.innerHeight);
        });
      });
  </script>
</body>
</html>