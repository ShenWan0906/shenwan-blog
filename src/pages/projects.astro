---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { projects } from "../constants/projects";
import { Icon } from "astro-icon/components";
import defaultCover from "../constants/images/cover.jpeg";

const title = "项目作品集";
const description = "西瓜主管的项目经验与技术成果展示";
---

<MainGridLayout title={title} description={description}>
  
  {/* 1. 头部介绍 */}
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-6">
    <div class="card-base z-10 px-6 md:px-9 pt-8 pb-8 relative w-full">
        <Icon name="material-symbols:rocket-launch-rounded" 
              class="absolute right-6 top-6 text-9xl -rotate-12 pointer-events-none text-[var(--primary)] opacity-10" />
        <h1 class="text-2xl md:text-3xl font-bold mb-3 flex items-center gap-3 text-[var(--primary)]">
            <Icon name="material-symbols:track-changes-rounded" /> 我的项目工坊
        </h1>
        <p class="text-sm md:text-base leading-relaxed max-w-2xl text-[var(--content)] dark:text-gray-300 opacity-80">
            这里陈列了我职业生涯中的关键战役。点击卡片可查看 <span class="text-[var(--primary)] font-bold">详细技术架构</span> 与 <span class="text-[var(--primary)] font-bold">职责描述</span>。
        </p>
    </div>
  </div>

  {/* 2. 项目卡片网格 */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-5 mb-8">
    {projects.map((project, index) => (
      <button 
        onclick={`document.getElementById('dialog-${index}').showModal()`}
        class="group relative flex flex-col h-full rounded-2xl transition-all duration-300 hover:-translate-y-1.5 text-left w-full"
      >
        <div class="card-base h-full flex flex-col overflow-hidden relative z-10 rounded-2xl transform-gpu transition-all duration-300 group-hover:shadow-xl group-hover:border-[var(--primary)]/30">
            
            {/* 图片区域 */}
            <div class="relative w-full aspect-[16/9] overflow-hidden bg-[var(--btn-content)]/5 rounded-t-2xl">
                <img 
                    src={project.image} 
                    alt={project.title} 
                    onerror={`this.onerror=null; this.src='${defaultCover.src}';`}
                    /* 深色模式：降低亮度，防止亮瞎眼 */
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 will-change-transform dark:brightness-75 dark:group-hover:brightness-100"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300"></div>
                
                {/* 年份标签 */}
                <div class="absolute top-3 left-3 flex items-center gap-1 bg-black/60 backdrop-blur-md text-white text-xs font-bold px-2.5 py-1 rounded-full border border-white/10 shadow-lg">
                    <Icon name="material-symbols:calendar-month-rounded" class="text-xs" />
                    {project.year}
                </div>
                
                {/* 提示：点击查看详情 */}
                <div class="absolute bottom-3 right-3 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                    <div class="bg-white text-black px-3 py-1.5 rounded-full shadow-lg text-xs font-bold flex items-center gap-1">
                        查看详情 <Icon name="material-symbols:arrow-outward-rounded" />
                    </div>
                </div>
            </div>

            {/* 内容区域 */}
            <div class="p-5 flex flex-col flex-1 relative">
                <div class="mb-3">
                    <span class="inline-flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-md text-[var(--primary)] bg-[var(--primary)]/10 border border-[var(--primary)]/15">
                        <Icon name="material-symbols:person-play-rounded" class="text-sm" />
                        {project.role}
                    </span>
                </div>
                {/* 标题：深色模式强制亮白 */}
                <h3 class="text-lg md:text-xl font-bold mb-2 line-clamp-1 transition-colors text-[var(--content)] dark:text-gray-100 group-hover:text-[var(--primary)]">
                    {project.title}
                </h3>
                {/* 描述：深色模式强制浅灰 */}
            <div class="relative mb-4 h-11 group-hover:h-auto group-hover:max-h-24 overflow-hidden group-hover:overflow-y-auto custom-scrollbar transition-all duration-300">
    <p class="text-sm leading-relaxed text-[var(--content)] opacity-60 dark:text-gray-400 dark:opacity-100 line-clamp-2 group-hover:line-clamp-none">
        {project.description}
    </p>
</div>
                <div class="mt-auto pt-4 border-t border-[var(--line-divider)]">
                    <div class="flex flex-wrap gap-2">
                        {project.tags.map(tag => (
                            <span class="text-[10px] md:text-xs px-2 py-1 rounded bg-[var(--btn-regular-bg)] text-[var(--content)] dark:text-gray-300 opacity-80 group-hover:bg-[var(--primary)]/10 group-hover:text-[var(--primary)] group-hover:opacity-100 transition-colors duration-300">
                                #{tag}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        </div>
      </button>
    ))}
  </div>

  {/* 3. 详情弹窗 (Modals) */}
  {projects.map((project, index) => (
    <dialog id={`dialog-${index}`} class="modal p-0 rounded-3xl backdrop:bg-black/60 backdrop:backdrop-blur-sm w-[90vw] max-w-3xl max-h-[85vh] overflow-hidden bg-white dark:bg-[#1e1e1e] shadow-2xl">
      <div class="flex flex-col h-full max-h-[85vh]">
        
        {/* Modal Header: 蓝底白字 (深色模式下背景变深蓝) */}
        <div class="relative bg-blue-500 dark:bg-blue-700 p-6 border-b border-blue-400/30 dark:border-blue-600 flex justify-between items-start shrink-0">
          <div>
            <h2 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-wide drop-shadow-sm">
                {project.title}
            </h2>
            <div class="flex flex-wrap gap-2">
               <span class="text-xs font-bold px-2 py-1 rounded bg-white/20 text-white border border-white/30 backdrop-blur-sm">
                  {project.role}
               </span>
               <span class="text-xs font-bold px-2 py-1 rounded bg-white/10 text-white/90 border border-white/20">
                  {project.year}
               </span>
            </div>
          </div>
          <form method="dialog">
            <button class="p-2 rounded-full hover:bg-white/20 text-white transition-colors">
              <Icon name="material-symbols:close-rounded" class="text-2xl" />
            </button>
          </form>
        </div>

        {/* Modal Content */}
        <div class="p-6 overflow-y-auto custom-scrollbar">
          
          {/* Section 1: 背景 */}
          <div class="mb-6">
            <h3 class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
              <Icon name="material-symbols:info-outline-rounded" /> 项目背景
            </h3>
            {/* 这里的文字强制适配深浅 */}
            <p class="leading-relaxed text-sm md:text-base text-gray-700 dark:text-gray-200">
              {project.details?.background || project.description}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            {/* Section 2: 技术架构 
                🌙 深色模式：深蓝背景 (blue-900/30) + 亮蓝标题 (blue-300) + 灰白文字 (gray-300)
            */}
            <div class="bg-blue-50 dark:bg-blue-900/20 p-5 rounded-xl border border-blue-100 dark:border-blue-500/20">
              <h3 class="text-sm font-bold text-blue-600 dark:text-blue-300 mb-3 flex items-center gap-2">
                <Icon name="material-symbols:code-blocks-rounded" /> 技术架构
              </h3>
              <ul class="space-y-2">
                {project.details?.tech.map(item => (
                  <li class="text-sm flex items-start gap-2 text-gray-700 dark:text-gray-300">
                    <span class="text-blue-500 dark:text-blue-400 mt-1">•</span> {item}
                  </li>
                ))}
              </ul>
            </div>

            {/* Section 3: 核心模块 */}
            <div class="bg-blue-50 dark:bg-blue-900/20 p-5 rounded-xl border border-blue-100 dark:border-blue-500/20">
              <h3 class="text-sm font-bold text-blue-600 dark:text-blue-300 mb-3 flex items-center gap-2">
                <Icon name="material-symbols:view-module-rounded" /> 核心模块
              </h3>
              <ul class="space-y-2">
                {project.details?.modules.map(item => (
                  <li class="text-sm flex items-start gap-2 text-gray-700 dark:text-gray-300">
                    <span class="text-blue-500 dark:text-blue-400 mt-1">•</span> {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          {/* Section 4: 我的职责 */}
          <div class="mb-2">
            <h3 class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-2">
              <Icon name="material-symbols:person-check-rounded" /> 核心职责 & 成果
            </h3>
            <div class="space-y-3">
              {project.details?.responsibility.map(item => (
                <div class="flex items-start gap-3">
                  <div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blue-500 dark:bg-blue-400 shrink-0"></div>
                  <p class="text-sm md:text-base leading-relaxed text-gray-700 dark:text-gray-200">{item}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </dialog>
  ))}

  <script is:inline>
    const dialogs = document.querySelectorAll('dialog');
    dialogs.forEach(dialog => {
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          dialog.close();
        }
      });
    });
  </script>

  <style>
    dialog[open] {
      animation: zoom-in 0.2s ease-out;
    }
    @keyframes zoom-in {
      from { transform: scale(0.95); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    /* 隐藏滚动条但保留滚动功能 (针对描述区域) */
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 10px;
    opacity: 0.5;
  }
  </style>

</MainGridLayout>