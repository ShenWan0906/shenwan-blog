---
// src/pages/projects.astro
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { projects } from "../constants/projects";
import { Icon } from "astro-icon/components";
import defaultCover from "../constants/images/cover.jpeg";

const title = "项目作品集";
const description = "西瓜主管的项目经验与技术成果展示";
---

<MainGridLayout title={title} description={description}>
  {/* 1. 头部介绍 */}
  <div
    class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-6"
  >
    <div class="card-base z-10 px-6 md:px-9 pt-8 pb-8 relative w-full">
      <Icon
        name="material-symbols:rocket-launch-rounded"
        class="absolute right-6 top-6 text-9xl -rotate-12 pointer-events-none text-[var(--primary)] opacity-10"
      />
      <h1
        class="text-2xl md:text-3xl font-bold mb-3 flex items-center gap-3 text-[var(--primary)]"
      >
        <Icon name="material-symbols:track-changes-rounded" /> 项目工坊
      </h1>
      <p
        class="text-sm md:text-base leading-relaxed max-w-2xl text-slate-600 dark:text-gray-300"
      >
        聚合技术深耕与管理沉淀。点击卡片下钻查看 <span
          class="text-[var(--primary)] font-bold">详细架构</span
        > 与 <span class="text-[var(--primary)] font-bold">复盘数据</span>。
      </p>
    </div>
  </div>

  {/* 2. 项目卡片网格 (核心变化：用 <a> 标签替代 <button>) */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-5 mb-8">
    {
      projects.map((project, index) => (
        <a
          href={`/project/${index}/`}
          class="group relative flex flex-col h-full rounded-2xl transition-all duration-300 hover:-translate-y-1.5 text-left w-full"
        >
          <div class="card-base h-full flex flex-col overflow-hidden relative z-10 rounded-2xl transform-gpu transition-all duration-300 group-hover:shadow-xl group-hover:border-[var(--primary)]/30">
            <div class="relative w-full aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-slate-800">
              <img
                src={project.image}
                alt={project.title}
                onerror={`this.onerror=null; this.src='${defaultCover.src}';`}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>

            <div class="p-5 flex flex-col flex-1 relative">
              <div class="mb-3">
                <span class="inline-flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-md text-[var(--primary)] bg-[var(--primary)]/10 border border-[var(--primary)]/15">
                  {project.role}
                </span>
              </div>
              <h3 class="text-lg font-bold mb-2 text-slate-800 dark:text-gray-100 group-hover:text-[var(--primary)]">
                {project.title}
              </h3>
              <p class="text-[14px] leading-relaxed text-slate-500 dark:text-gray-400 line-clamp-4">{project.description}</p>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</MainGridLayout>
